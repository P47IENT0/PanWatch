# AI 配置
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=your_key_here
AI_MODEL=glm-4

# 通知配置 - Telegram
NOTIFY_TELEGRAM_BOT_TOKEN=your_bot_token
NOTIFY_TELEGRAM_CHAT_ID=your_chat_id

# 代理配置（国内访问 Telegram 可能需要）
# HTTP_PROXY=http://127.0.0.1:7890

# SSL 企业证书（Zscaler 等企业代理环境需要，留空则不启用）
# CA_CERT_FILE=/path/to/your/enterprise-cert.crt

# 调度配置（cron 表达式：分 时 日 月 周）
DAILY_REPORT_CRON=30 15 * * 1-5

# 可选：环境变量驱动的多供应商/多模型同步（启动时自动写入数据库）
# 说明：使用 JSON 单行字符串；如果不配置，继续使用 UI 中的服务商与模型。
# PANWATCH_AI_SERVICES_JSON=[{"name":"CodeYY OpenAI Group","base_url":"https://codeyy.top/v1","api_key":"sk-xxx","models":[{"name":"GPT-4o","model":"gpt-4o"},{"name":"GPT-4o Mini","model":"gpt-4o-mini"}]},{"name":"CodeYY Gemini","base_url":"https://codeyy.top/v1beta","api_key":"sk-yyy","models":[{"name":"Gemini 3 Pro","model":"gemini-3-pro-preview"},{"name":"Gemini 3 Flash","model":"gemini-3-flash-preview"}]}]
# PANWATCH_AI_AGENT_MODEL_MAP_JSON={"premarket_outlook":"gpt-5.2-codex-xhigh","intraday_monitor":"gpt-4o-mini","daily_report":"gpt-4o","news_digest":"gemini-3-flash-preview","chart_analyst":"gemini-3-pro-preview"}
# PANWATCH_AI_DEFAULT_MODEL=gpt-4o
